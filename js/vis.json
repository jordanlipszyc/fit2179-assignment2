{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": "container",
  "data": {
    "url": "data/DELETE.csv"
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "daily_cost",
      "type": "quantitative",
      "title": "Daily cost ($)"
    },
    "y": {
      "field": "city",
      "type": "nominal",
      "title": "",
      "sort": { "encoding": "x", "order": "ascending" }
    }
  },
  "config": {
    "background": "#fffccb",
    "axis": {
      "titleColor": "#3c1518",
      "labelColor": "#3c1518",
      "labelFont": "sans-serif",
      "labelFontSize": 15,
      "titleFontSize": 15
    }
  }
}
