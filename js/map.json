{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Australia Choropleth Example",
  "width": 800,
  "height": 600,
  "projection": { "type": "mercator" },

  "data": {
    "url": "../data/test.topojson",
    "format": {
      "type": "topojson",
      "feature": "ne_50m_admin_1_states_provinces"
    }
  },

  "transform": [
    {
      "lookup": "properties.name",
      "from": {
        "data": {
          "url": "../data/made-up-choropleth.csv"
        },
        "key": "State",
        "fields": ["Value"]
      }
    }
  ],

  "mark": { "type": "geoshape", "stroke": "#333", "strokeWidth": 0.5 },

  "encoding": {
    "color": {
      "field": "Value",
      "type": "quantitative",
      "scale": { "scheme": "blues" },
      "title": "Value"
    },
    "tooltip": [
      { "field": "properties.NAME", "title": "State" },
      { "field": "Value", "title": "Value" }
    ]
  }
}
